generator client {
  provider      = "prisma-client-js"
  output        = "../node_modules/.prisma/client"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                       String                @id @default(cuid())
  name                     String?
  firstName                String?
  lastName                 String?
  email                    String                @unique
  password                 String?
  emailVerified            DateTime?
  image                    String?
  phone                    String?
  role                     UserRole              @default(CLIENTE)
  isActive                 Boolean               @default(true)
  sucursal                 String?
  lastLogin                DateTime?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  sucursalDefaultId        String?
  accounts                 Account[]
  sessions                 Session[]
  sucursalDefault          Sucursal?             @relation("UserSucursalDefault", fields: [sucursalDefaultId], references: [id])
  agentes                  Agente[]
  auditLogs                AuditLog[]
  clientesAsignados        Cliente[]             @relation("ClienteGestor")
  garantiasAtendidas       Garantia[]            @relation("GarantiaAtendida")
  notasCargoAplicadas      NotaCargo[]           @relation("NotaCargoAplicadaPor")
  notasCreditoAplicadas    NotaCredito[]         @relation("NotaCreditoAplicadaPor")
  pagosGestionados         Pago[]                @relation("PagoGestor")
  pedidosCreados           Pedido[]              @relation("PedidoVendedor")
  reestructurasAutorizadas ReestructuraCredito[] @relation("ReestructuraAutorizada")
  sesionesCAja             SesionCaja[]          @relation("CajeroPOS")
  ventasCreadas            Venta[]               @relation("VentaCreador")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Configuracion {
  id              String   @id @default(cuid())
  nombreEmpresa   String   @default("Sistema ERP")
  logoUrl         String?
  colorPrimario   String   @default("#3B82F6")
  colorSecundario String   @default("#10B981")
  direccion       String?
  telefono        String?
  email           String?
  rfc             String?
  configJson      Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Cliente {
  id                  String                @id @default(cuid())
  codigoCliente       String                @unique
  contrato            String?
  nombre              String
  telefono1           String?
  telefono2           String?
  telefono3           String?
  email               String?
  calle               String?
  numeroExterior      String?
  numeroInterior      String?
  colonia             String?
  municipio           String?
  estado              String?
  codigoPostal        String?
  latitud             String?
  longitud            String?
  saldoActual         Float                 @default(0)
  pagosPeriodicos     Float                 @default(0)
  periodicidad        Periodicidad          @default(SEMANAL)
  diaCobro            String?
  diaPago             String?
  statusCuenta        String?
  limiteCredito       Float                 @default(0)
  rfc                 String?
  usoCfdi             String?               @default("G03")
  metodoPago          String?               @default("PUE")
  cuentaPago          String?
  regimenFiscal       String?
  codigoPostalFiscal  String?
  contpaqiCodigo      String?               @unique
  contpaqiSyncAt      DateTime?
  empleo              String?
  aval                String?
  status              StatusCliente         @default(ACTIVO)
  gestorId            String?
  vendedorId          String?
  fechaAlta           DateTime              @default(now())
  ultimaActualizacion DateTime              @default(now()) @updatedAt
  listaPrecio         Int?
  descuento           Float                 @default(0)
  gestor              User?                 @relation("ClienteGestor", fields: [gestorId], references: [id])
  creditoHistorial    CreditoHistorial[]
  garantias           Garantia[]
  notasCargo          NotaCargo[]
  notasCredito        NotaCredito[]
  pagos               Pago[]
  pedidos             Pedido[]
  reestructuras       ReestructuraCredito[]
  ventas              Venta[]

  @@map("clientes")
}

model Producto {
  id                    String                 @id @default(cuid())
  codigo                String                 @unique
  nombre                String
  descripcion           String?
  categoria             String?
  marca                 String?
  modelo                String?
  codigoBarras          String?
  presentacion          String?
  contenido             String?
  peso                  Float?
  dimensiones           String?
  color                 String?
  talla                 String?
  precio1               Float                  @default(0)
  precio2               Float                  @default(0)
  precio3               Float                  @default(0)
  precio4               Float                  @default(0)
  precio5               Float                  @default(0)
  etiquetaPrecio1       String                 @default("Público")
  etiquetaPrecio2       String                 @default("Mayorista")
  etiquetaPrecio3       String                 @default("Distribuidor")
  etiquetaPrecio4       String                 @default("Especial")
  etiquetaPrecio5       String                 @default("Promocional")
  precioCompra          Float                  @default(0)
  porcentajeGanancia    Float                  @default(0)
  descuento             Float                  @default(0)
  unidadMedida          String                 @default("PZA")
  claveSat              String?
  claveUnidadSat        String?
  contpaqiCodigo        String?                @unique
  contpaqiSyncAt        DateTime?
  pasillo               String?
  estante               String?
  nivel                 String?
  proveedorPrincipal    String?
  tiempoEntrega         Int?                   @default(0)
  fechaVencimiento      DateTime?
  lote                  String?
  requiereReceta        Boolean                @default(false)
  controlado            Boolean                @default(false)
  imagen                String?
  imagenes              String[]
  isActive              Boolean                @default(true)
  destacado             Boolean                @default(false)
  oferta                Boolean                @default(false)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  compraItems           CompraItem[]
  detallesNotaCredito   DetalleNotaCredito[]
  detallesPedido        DetallePedido[]
  detallesTransferencia DetalleTransferencia[]
  detallesVenta         DetalleVenta[]
  garantias             Garantia[]
  garantiasReemplazo    Garantia[]             @relation("ProductoReemplazoGarantia")
  movimientos           MovimientoInventario[]
  stockSucursales       StockSucursal[]

  @@map("productos")
}

model Proveedor {
  id              String           @id @default(cuid())
  codigo          String           @unique
  nombre          String
  contacto        String?
  telefono        String?
  email           String?
  direccion       String?
  rfc             String?
  diasCredito     Int              @default(0)
  limiteCredito   Float            @default(0)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  compras         Compra[]
  cuentasPorPagar CuentaPorPagar[]

  @@map("proveedores")
}

model Servicio {
  id             String            @id @default(cuid())
  codigo         String            @unique
  nombre         String
  descripcion    String?
  categoria      CategoriaServicio @default(OTRO)
  precio         Float             @default(0)
  unidad         String            @default("Servicio")
  isActive       Boolean           @default(true)
  claveSat       String?
  claveUnidadSat String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@map("servicios")
}

model Pedido {
  id                   String          @id @default(cuid())
  folio                String          @unique
  clienteId            String
  vendedorId           String
  subtotal             Float
  iva                  Float           @default(0)
  descuento            Float           @default(0)
  total                Float
  estatus              StatusPedido    @default(PENDIENTE)
  prioridad            PrioridadPedido @default(NORMAL)
  observaciones        String?
  fechaPedido          DateTime        @default(now())
  fechaEntregaEstimada DateTime?
  fechaVencimiento     DateTime?
  convertidoAVenta     Boolean         @default(false)
  ventaId              String?         @unique
  motivoCancelacion    String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  sucursalId           String?
  detalles             DetallePedido[]
  cliente              Cliente         @relation(fields: [clienteId], references: [id])
  sucursal             Sucursal?       @relation(fields: [sucursalId], references: [id])
  vendedor             User            @relation("PedidoVendedor", fields: [vendedorId], references: [id])
  venta                Venta?          @relation("PedidoToVenta", fields: [ventaId], references: [id])

  @@map("pedidos")
}

model DetallePedido {
  id             String   @id @default(cuid())
  pedidoId       String
  productoId     String
  cantidad       Float
  precioUnitario Float
  descuento      Float    @default(0)
  subtotal       Float
  observaciones  String?
  pedido         Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  producto       Producto @relation(fields: [productoId], references: [id])

  @@map("detalle_pedidos")
}

model Venta {
  id                        String                @id @default(cuid())
  folio                     String                @unique @default(cuid())
  numeroFactura             String?               @unique
  clienteId                 String
  vendedorId                String
  pedidoId                  String?               @unique
  subtotal                  Float
  iva                       Float                 @default(0)
  descuento                 Float                 @default(0)
  total                     Float
  pagoInicial               Float                 @default(0)
  saldoPendiente            Float                 @default(0)
  periodicidadPago          Periodicidad          @default(SEMANAL)
  montoPago                 Float                 @default(0)
  numeroPagos               Int                   @default(1)
  fechaProximoPago          DateTime?
  diasGracia                Int                   @default(0)
  status                    StatusVenta           @default(PENDIENTE)
  fechaVenta                DateTime              @default(now())
  contpaqiDocId             Int?
  contpaqiSerie             String?
  contpaqiFolio             Float?
  contpaqiConcepto          String?
  timbrado                  Boolean               @default(false)
  uuid                      String?
  xmlPath                   String?
  pdfPath                   String?
  contpaqiSyncAt            DateTime?
  fechaVencimiento          DateTime?
  inventarioAfectado        Boolean               @default(false)
  fechaAfectacionInventario DateTime?
  observaciones             String?
  notasInternas             String?
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  sucursalId                String?
  detalles                  DetalleVenta[]
  garantias                 Garantia[]
  notasCargo                NotaCargo[]
  notasCredito              NotaCredito[]
  pagares                   Pagare[]
  pagos                     Pago[]
  pedidoOrigen              Pedido?               @relation("PedidoToVenta")
  reestructuras             ReestructuraCredito[]
  cliente                   Cliente               @relation(fields: [clienteId], references: [id])
  sucursal                  Sucursal?             @relation(fields: [sucursalId], references: [id])
  vendedor                  User                  @relation("VentaCreador", fields: [vendedorId], references: [id])
  ventaPOS                  VentaPOS?             @relation("VentaToVentaPOS")

  @@index([clienteId])
  @@map("ventas")
}

model DetalleVenta {
  id             String   @id @default(cuid())
  ventaId        String
  productoId     String
  cantidad       Float
  precioUnitario Float
  descuento      Float    @default(0)
  subtotal       Float
  tiempoGarantia Int?
  observaciones  String?
  producto       Producto @relation(fields: [productoId], references: [id])
  venta          Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)

  @@map("detalle_ventas")
}

model Pagare {
  id               String              @id @default(cuid())
  ventaId          String
  numeroPago       Int
  monto            Float
  fechaVencimiento DateTime
  estatus          StatusPagare        @default(PENDIENTE)
  fechaPago        DateTime?
  montoPagado      Float               @default(0)
  diasVencido      Int                 @default(0)
  tasaInteresMora  Float               @default(0)
  interesesMora    Float               @default(0)
  interesesPagados Float               @default(0)
  observaciones    String?
  calculadoAlCorte DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  detallesPago     DetallePagoPagare[]
  venta            Venta               @relation(fields: [ventaId], references: [id])

  @@index([ventaId])
  @@map("pagares")
}

model DetallePagoPagare {
  id              String   @id @default(cuid())
  pagareId        String
  pagoId          String
  montoAplicado   Float
  aplicadoCapital Float
  aplicadoInteres Float
  fechaAplicacion DateTime @default(now())
  pagare          Pagare   @relation(fields: [pagareId], references: [id])
  pago            Pago     @relation(fields: [pagoId], references: [id])

  @@map("detalle_pago_pagares")
}

model NotaCargo {
  id              String            @id @default(cuid())
  folio           String            @unique
  clienteId       String
  ventaId         String?
  concepto        ConceptoNotaCargo
  descripcion     String
  monto           Float
  referencia      String?
  aplicada        Boolean           @default(false)
  fechaAplicacion DateTime?
  aplicadaPorId   String?
  fecha           DateTime          @default(now())
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  aplicadaPor     User?             @relation("NotaCargoAplicadaPor", fields: [aplicadaPorId], references: [id])
  cliente         Cliente           @relation(fields: [clienteId], references: [id])
  venta           Venta?            @relation(fields: [ventaId], references: [id])

  @@map("notas_cargo")
}

model NotaCredito {
  id                 String               @id @default(cuid())
  folio              String               @unique
  clienteId          String
  ventaId            String?
  concepto           ConceptoNotaCredito
  descripcion        String
  monto              Float
  referencia         String?
  afectaInventario   Boolean              @default(false)
  inventarioAfectado Boolean              @default(false)
  aplicada           Boolean              @default(false)
  fechaAplicacion    DateTime?
  aplicadaPorId      String?
  fecha              DateTime             @default(now())
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  detalles           DetalleNotaCredito[]
  aplicadaPor        User?                @relation("NotaCreditoAplicadaPor", fields: [aplicadaPorId], references: [id])
  cliente            Cliente              @relation(fields: [clienteId], references: [id])
  venta              Venta?               @relation(fields: [ventaId], references: [id])

  @@map("notas_credito")
}

model DetalleNotaCredito {
  id             String      @id @default(cuid())
  notaCreditoId  String
  productoId     String?
  cantidad       Float?
  precioUnitario Float?
  subtotal       Float
  motivo         String
  notaCredito    NotaCredito @relation(fields: [notaCreditoId], references: [id], onDelete: Cascade)
  producto       Producto?   @relation(fields: [productoId], references: [id])

  @@map("detalle_notas_credito")
}

model ReestructuraCredito {
  id                       String             @id @default(cuid())
  ventaId                  String
  clienteId                String
  saldoAnterior            Float
  periodicidadAnterior     Periodicidad
  montoPagoAnterior        Float
  numeroPagosAnterior      Int
  fechaProximoPagoAnterior DateTime?
  saldoNuevo               Float
  periodicidadNueva        Periodicidad
  montoPagoNuevo           Float
  numeroPagosNuevo         Int
  fechaProximoPagoNueva    DateTime
  motivo                   MotivoReestructura
  observaciones            String?
  descuentoOtorgado        Float              @default(0)
  interesesCondonados      Float              @default(0)
  autorizadaPorId          String
  fechaReestructura        DateTime           @default(now())
  activa                   Boolean            @default(true)
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  autorizadaPor            User               @relation("ReestructuraAutorizada", fields: [autorizadaPorId], references: [id])
  cliente                  Cliente            @relation(fields: [clienteId], references: [id])
  venta                    Venta              @relation(fields: [ventaId], references: [id])

  @@map("reestructuras_credito")
}

model Garantia {
  id                  String         @id @default(cuid())
  folio               String         @unique
  clienteId           String
  ventaId             String
  productoId          String
  tipoGarantia        TipoGarantia
  fechaCompra         DateTime
  fechaInicioGarantia DateTime
  fechaFinGarantia    DateTime
  mesesGarantia       Int
  estatus             StatusGarantia @default(ACTIVA)
  fechaReclamo        DateTime?
  descripcionFalla    String?
  diagnostico         String?
  solucionAplicada    String?
  requiereReemplazo   Boolean        @default(false)
  productoReemplazoId String?
  costoReparacion     Float?
  costoReemplazo      Float?
  afectaInventario    Boolean        @default(false)
  inventarioAfectado  Boolean        @default(false)
  atendidaPorId       String?
  fechaRecepcion      DateTime?
  fechaEntrega        DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  atendidaPor         User?          @relation("GarantiaAtendida", fields: [atendidaPorId], references: [id])
  cliente             Cliente        @relation(fields: [clienteId], references: [id])
  producto            Producto       @relation(fields: [productoId], references: [id])
  productoReemplazo   Producto?      @relation("ProductoReemplazoGarantia", fields: [productoReemplazoId], references: [id])
  venta               Venta          @relation(fields: [ventaId], references: [id])

  @@map("garantias")
}

model Pago {
  id              String              @id @default(cuid())
  clienteId       String
  ventaId         String?
  gestorId        String?
  referencia      String
  folio           String?             @unique
  monto           Float
  tipoPago        TipoPago            @default(EFECTIVO)
  aplicadoCapital Float               @default(0)
  aplicadoInteres Float               @default(0)
  fechaPago       DateTime            @default(now())
  fechaHora       DateTime            @default(now())
  latitud         String?
  longitud        String?
  sucursal        String?
  verificado      Boolean             @default(false)
  sincronizado    Boolean             @default(false)
  deviceImei      String?
  observaciones   String?
  concepto        String?
  detallesPagares DetallePagoPagare[]
  cliente         Cliente             @relation(fields: [clienteId], references: [id])
  gestor          User?               @relation("PagoGestor", fields: [gestorId], references: [id])
  venta           Venta?              @relation(fields: [ventaId], references: [id])

  @@index([clienteId])
  @@map("pagos")
}

model Compra {
  id              String           @id @default(cuid())
  numeroCompra    String           @unique
  proveedorId     String
  subtotal        Float
  iva             Float            @default(0)
  total           Float
  status          StatusCompra     @default(PENDIENTE)
  fechaCompra     DateTime         @default(now())
  fechaRecepcion  DateTime?
  observaciones   String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  items           CompraItem[]
  proveedor       Proveedor        @relation(fields: [proveedorId], references: [id])
  cuentasPorPagar CuentaPorPagar[]

  @@map("compras")
}

model CompraItem {
  id             String   @id @default(cuid())
  compraId       String
  productoId     String
  cantidad       Int
  precioUnitario Float
  subtotal       Float
  compra         Compra   @relation(fields: [compraId], references: [id], onDelete: Cascade)
  producto       Producto @relation(fields: [productoId], references: [id])

  @@map("compra_items")
}

model MovimientoInventario {
  id               String         @id @default(cuid())
  productoId       String
  tipo             TipoMovimiento
  cantidad         Int
  cantidadAnterior Int
  cantidadNueva    Int
  motivo           String
  referencia       String?
  fechaMovimiento  DateTime       @default(now())
  userId           String?
  sucursalId       String?
  producto         Producto       @relation(fields: [productoId], references: [id])
  sucursal         Sucursal?      @relation(fields: [sucursalId], references: [id])

  @@index([productoId])
  @@map("movimientos_inventario")
}

model CuentaPorPagar {
  id               String           @id @default(cuid())
  proveedorId      String
  compraId         String?
  numeroFactura    String
  monto            Float
  montoRestante    Float
  fechaVencimiento DateTime
  status           StatusCuentaPago @default(PENDIENTE)
  observaciones    String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  compra           Compra?          @relation(fields: [compraId], references: [id])
  proveedor        Proveedor        @relation(fields: [proveedorId], references: [id])

  @@index([proveedorId])
  @@map("cuentas_por_pagar")
}

model CreditoHistorial {
  id            String   @id @default(cuid())
  clienteId     String
  evento        String
  montoAnterior Float
  montoNuevo    Float
  observaciones String?
  fechaEvento   DateTime @default(now())
  cliente       Cliente  @relation(fields: [clienteId], references: [id])

  @@map("credito_historial")
}

model AuditLog {
  id              String   @id @default(cuid())
  userId          String?
  accion          String
  tabla           String
  registroId      String
  datosAnteriores Json?
  datosNuevos     Json?
  ip              String?
  userAgent       String?
  createdAt       DateTime @default(now())
  user            User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Agente {
  id         String   @id @default(cuid())
  contpaqiId Int      @unique
  codigo     String   @unique
  nombre     String
  tipo       Int      @default(1)
  isActive   Boolean  @default(true)
  userId     String?
  syncAt     DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@map("agentes")
}

model Almacen {
  id         String   @id @default(cuid())
  contpaqiId Int      @unique
  codigo     String   @unique
  nombre     String
  isActive   Boolean  @default(true)
  syncAt     DateTime @default(now())

  @@map("almacenes")
}

model SyncLog {
  id          String   @id @default(cuid())
  tipo        String
  accion      String
  entidadId   String
  contpaqiRef String?
  status      String
  detalles    Json?
  error       String?
  createdAt   DateTime @default(now())

  @@map("sync_logs")
}

model Sucursal {
  id                    String                    @id @default(cuid())
  codigo                String                    @unique
  nombre                String
  direccion             String?
  telefono              String?
  email                 String?
  listaPrecioDefecto    Int                       @default(1)
  impuestoIncluido      Boolean                   @default(false)
  isActive              Boolean                   @default(true)
  esMatriz              Boolean                   @default(false)
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  usuariosDefault       User[]                    @relation("UserSucursalDefault")
  movimientos           MovimientoInventario[]
  pedidos               Pedido[]
  sesiones              SesionCaja[]
  stockProductos        StockSucursal[]
  transferenciasDestino TransferenciaInventario[] @relation("TransferenciaDestino")
  transferenciasOrigen  TransferenciaInventario[] @relation("TransferenciaOrigen")
  ventas                Venta[]

  @@map("sucursales")
}

model StockSucursal {
  id          String   @id @default(cuid())
  sucursalId  String
  productoId  String
  stock       Int      @default(0)
  stockMinimo Int      @default(0)
  stockMaximo Int      @default(1000)
  updatedAt   DateTime @updatedAt
  producto    Producto @relation(fields: [productoId], references: [id])
  sucursal    Sucursal @relation(fields: [sucursalId], references: [id])

  @@unique([sucursalId, productoId])
  @@index([sucursalId])
  @@map("stock_sucursales")
}

model TransferenciaInventario {
  id                String                 @id @default(cuid())
  folio             String                 @unique
  sucursalOrigenId  String
  sucursalDestinoId String
  usuarioId         String
  estatus           StatusTransferencia    @default(PENDIENTE)
  observaciones     String?
  fechaSolicitud    DateTime               @default(now())
  fechaEnvio        DateTime?
  fechaRecepcion    DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  detalles          DetalleTransferencia[]
  sucursalDestino   Sucursal               @relation("TransferenciaDestino", fields: [sucursalDestinoId], references: [id])
  sucursalOrigen    Sucursal               @relation("TransferenciaOrigen", fields: [sucursalOrigenId], references: [id])

  @@map("transferencias_inventario")
}

model DetalleTransferencia {
  id                 String                  @id @default(cuid())
  transferenciaId    String
  productoId         String
  cantidadSolicitada Int
  cantidadEnviada    Int                     @default(0)
  cantidadRecibida   Int                     @default(0)
  producto           Producto                @relation(fields: [productoId], references: [id])
  transferencia      TransferenciaInventario @relation(fields: [transferenciaId], references: [id], onDelete: Cascade)

  @@map("detalle_transferencias")
}

model SesionCaja {
  id                     String           @id @default(cuid())
  cajeroId               String
  sucursalId             String
  numeroTerminal         String?
  fechaApertura          DateTime         @default(now())
  montoApertura          Float            @default(0)
  fechaCierre            DateTime?
  montoEfectivoDeclarado Float?
  totalEfectivoSistema   Float?
  totalTarjetaSistema    Float?
  totalVentas            Float?
  totalTransacciones     Int?
  diferencia             Float?
  observacionesCierre    String?
  activa                 Boolean          @default(true)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  movimientos            MovimientoCaja[]
  cajero                 User             @relation("CajeroPOS", fields: [cajeroId], references: [id])
  sucursal               Sucursal         @relation(fields: [sucursalId], references: [id])
  ventasPOS              VentaPOS[]

  @@index([cajeroId])
  @@index([sucursalId])
  @@map("sesiones_caja")
}

model MovimientoCaja {
  id         String             @id @default(cuid())
  sesionId   String
  tipo       TipoMovimientoCaja
  monto      Float
  concepto   String
  referencia String?
  createdAt  DateTime           @default(now())
  sesion     SesionCaja         @relation(fields: [sesionId], references: [id])

  @@index([sesionId])
  @@map("movimientos_caja")
}

model VentaPOS {
  id                 String     @id @default(cuid())
  sesionId           String
  ventaId            String     @unique
  numeroTicket       String     @unique
  pagoEfectivo       Float      @default(0)
  pagoTarjeta        Float      @default(0)
  referenciaTerminal String?
  cambio             Float      @default(0)
  listaPrecioUsada   Int        @default(1)
  createdAt          DateTime   @default(now())
  sesion             SesionCaja @relation(fields: [sesionId], references: [id])
  venta              Venta      @relation("VentaToVentaPOS", fields: [ventaId], references: [id])

  @@map("ventas_pos")
}

